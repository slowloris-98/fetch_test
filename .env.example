# Copy to .env and adjust. Loaded into your shell before running `python agent.py`.

# Stable seed -> stable agent address. CHANGE THIS to your own secret phrase.
AGENT_SEED=baba-babooshka-seed-change-me

# Optional agent identity / networking
AGENT_NAME=baba_babooshka
AGENT_PORT=8000

# Directory Claude Code runs in. Use a dedicated/sandboxed project dir:
# the spawned Claude runs with --dangerously-skip-permissions and can run any
# tool (edit files, run commands) inside this directory.
CLAUDE_WORKDIR=d:/Atreya/College/Projects/fetch_test/workspace

# Model passed to `claude --model`. Leave blank to use Claude Code's default.
CLAUDE_MODEL=claude-opus-4-8

# Safety bounds for a single spawned run.
CLAUDE_TIMEOUT=600
CLAUDE_MAX_TURNS=40
